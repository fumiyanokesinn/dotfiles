{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux-settings.schema.json",
  "schemaVersion": 1,

  // kitty のキーバインドにできる限り合わせる。
  // - cmd+d / cmd+shift+d  : 分割（kitty と同一、cmux デフォルトと一致）
  // - cmd+] / cmd+[       : ワークスペース切替（サイドバータブ前後）
  // - cmd+shift+] / [     : サーフェス（タブ相当）切替
  // - cmd+w               : 閉じる（一致）
  // - cmd+f               : 検索（一致）
  //
  "shortcuts": {
    "bindings": {
      "newTab": "cmd+t",
      "newSurface": "cmd+opt+t",
      "nextSidebarTab": "cmd+]",
      "prevSidebarTab": "cmd+[",
      "nextSurface": "cmd+shift+]",
      "prevSurface": "cmd+shift+[",
      "browserBack": "cmd+opt+[",
      "browserForward": "cmd+opt+]",
      "focusLeft": "cmd+h",
      "focusDown": "cmd+j",
      "focusUp": "cmd+k",
      "focusRight": "cmd+l"
    }
  },

  // 視力配慮: 赤＋全面塗りで非フォーカス時も視界周辺で認識可
  "workspaceColors": {
    "notificationBadgeColor": "#FF3B30",
    "indicatorStyle": "solidFill"
  },

  // 通知: OS ポップアップと音は cmux-notify.sh（日本語）に一本化
  //   - cmux 本体の OS 通知ポップアップは macOS システム設定 > 通知 > cmux で OFF 推奨
  //   - cmux は dockBadge / paneFlash / menuBar 等の cmux 内可視化のみ担当
  //   - sound: "none" で cmux 側の音抑止（hook script 側で afplay 発行）
  "notifications": {
    "sound": "none",
    "dockBadge": true,
    "unreadPaneRing": true,
    "paneFlash": true,
    "showInMenuBar": true
  }
}
