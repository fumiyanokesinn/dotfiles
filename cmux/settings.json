{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux-settings.schema.json",
  "schemaVersion": 1,

  // kitty のキーバインドにできる限り合わせる。
  // - cmd+d / cmd+shift+d  : 分割（kitty と同一、cmux デフォルトと一致）
  // - cmd+] / cmd+[       : ワークスペース切替（サイドバータブ前後）
  // - cmd+shift+] / [     : サーフェス（タブ相当）切替
  // - cmd+w               : 閉じる（一致）
  // - cmd+f               : 検索（一致）
  //
  "shortcuts": {
    "bindings": {
      "newTab": "cmd+t",
      "newSurface": "cmd+opt+t",
      "nextSidebarTab": "cmd+]",
      "prevSidebarTab": "cmd+[",
      "nextSurface": "cmd+shift+]",
      "prevSurface": "cmd+shift+[",
      "browserBack": "cmd+opt+[",
      "browserForward": "cmd+opt+]",
      "focusLeft": "cmd+h",
      "focusDown": "cmd+j",
      "focusUp": "cmd+k",
      "focusRight": "cmd+l"
    }
  },

  // 視力配慮: 赤＋全面塗りで非フォーカス時も視界周辺で認識可
  "workspaceColors": {
    "notificationBadgeColor": "#FF3B30",
    "indicatorStyle": "solidFill"
  },

  // 通知: cmux-notify.sh は Claude Code のイベントを cmux 本体に転送するのみ
  //   - OS ポップアップは cmux 本体が発火（macOS システム設定 > 通知 > cmux で調整）
  //   - 音は cmux 本体が発火（下記 sound プリセット）
  //   - dockBadge / paneFlash / menuBar 等の可視化も cmux 本体が担当
  "notifications": {
    "sound": "Glass",
    "dockBadge": true,
    "unreadPaneRing": true,
    "paneFlash": true,
    "showInMenuBar": true
  }
}
