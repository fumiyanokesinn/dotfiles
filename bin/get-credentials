#!/bin/bash
set -euo pipefail

# setup-keychain で登録した認証情報を Keychain から取得して環境変数形式で出力する。
#
# 使い方:
#   get-credentials <service>           # ADMIN_USER / ADMIN_PASSWORD 形式で出力
#   eval "$(get-credentials <service>)" # 環境変数にロード（推奨）
#
# 例:
#   eval "$(get-credentials basemachina)"
#   echo "$ADMIN_USER"
#
# 出力形式:
#   ADMIN_USER=<username>
#   ADMIN_PASSWORD=<password>

SERVICE_PREFIX="user-creds"

if [[ $# -eq 0 || "$1" == "--help" || "$1" == "-h" ]]; then
  cat <<EOF
使い方:
  get-credentials <service>
  eval "\$(get-credentials <service>)"

例:
  eval "\$(get-credentials basemachina)"
EOF
  exit 1
fi

SERVICE_NAME="$1"
FULL_SERVICE="${SERVICE_PREFIX}/${SERVICE_NAME}"

username=$(security find-generic-password -s "$FULL_SERVICE" -a "username" -w 2>/dev/null) || {
  echo "ERROR: ${FULL_SERVICE} のユーザー名が未登録" >&2
  echo "  setup-keychain ${SERVICE_NAME} を実行して登録してください" >&2
  exit 1
}

password=$(security find-generic-password -s "$FULL_SERVICE" -a "password" -w 2>/dev/null) || {
  echo "ERROR: ${FULL_SERVICE} のパスワードが未登録" >&2
  echo "  setup-keychain ${SERVICE_NAME} を実行して登録してください" >&2
  exit 1
}

echo "ADMIN_USER=${username}"
echo "ADMIN_PASSWORD=${password}"
